{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["name", "era", "data"],
  "properties": {
    "name": { "type": "string" },
    "era": { "type": "string" },
    "description": { "type": "string" },
    "engine": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["factions", "terrain", "structures"],
      "additionalProperties": { "type": "string" },
      "properties": {
        "factions": { "type": "string" },
        "terrain": { "type": "string" },
        "structures": { "type": "string" }
      }
    },
    "pending": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
